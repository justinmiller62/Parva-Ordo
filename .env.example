# Local development environment (copy to .env). Docker Compose defaults below.

# Superuser connection — used ONLY by migrations and the seed.
MIGRATION_DATABASE_URL=postgres://postgres:postgres@localhost:5432/parvaordo

# App-role connection — RLS-enforced. Used by the app runtime and integration tests.
DATABASE_URL=postgres://parvaordo_app:app_local_pw@localhost:5432/parvaordo
